# See https://help.github.com/articles/ignoring-files/

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
Thumbs.db
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Env con secretos: nunca commit. Las mismas claves van en Vercel → Environment Variables.
# Plantillas versionadas: .env.local.example (sin valores reales).
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test

# Vinculo local del CLI de Vercel (no va al repo).
.vercel

# typescript
*.tsbuildinfo
